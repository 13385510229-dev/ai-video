# Supabase 配置
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# JWT 密钥（自定义任意字符串）
JWT_SECRET=your_jwt_secret_key_here

# 管理员密码
ADMIN_PASSWORD=

# Agnes AI API Key（可选，不配置则使用模拟模式）
AGNES_API_KEY=

# Resend API Key（可选，不配置则使用模拟模式，验证码打印在控制台）
RESEND_API_KEY=

# 发件邮箱配置
SMTP_FROM_EMAIL=your@email.com
SMTP_FROM_NAME=AI Video Generator

# 支付模式（manual 为手动确认支付）
PAYMENT_MODE=manual

# 收款码图片 URL（可选）
PAYMENT_QR_CODE=
